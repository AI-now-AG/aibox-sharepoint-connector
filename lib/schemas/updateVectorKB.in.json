{
    "type": "object",
    "properties": {
        "requestBody": {
            "type": "object",
            "required": [
                "tenant_id",
                "folder_id",
                "user_id",
                "external_file_id",
                "file_name",
                "is_deleted"
            ],
            "properties": {
                "tenant_id": {
                    "type": "string",
                    "description": "aibox tenant ID (MongoDB ObjectId)",
                    "example": "6579a1b2c3d4e5f678901234"
                },
                "folder_id": {
                    "type": "string",
                    "description": "Vector KB folder ID (MongoDB ObjectId)",
                    "example": "6579a1b2c3d4e5f678905678"
                },
                "user_id": {
                    "type": "string",
                    "description": "aibox user ID who set up the integration (MongoDB ObjectId)",
                    "example": "6579a1b2c3d4e5f678909012"
                },
                "external_file_id": {
                    "type": "string",
                    "description": "Unique file identifier from the source system (e.g., SharePoint item ID)",
                    "example": "01ABCDEFGHIJKLMNOP"
                },
                "file_name": {
                    "type": "string",
                    "description": "File name including extension (used for type detection)",
                    "example": "Corporate-Policy-2024.pdf"
                },
                "download_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to download the file content. Required when is_deleted is false.",
                    "example": "https://graph.microsoft.com/v1.0/sites/.../content"
                },
                "is_deleted": {
                    "type": "boolean",
                    "description": "If true, the file and its chunks will be removed from Vector KB"
                }
            }
        }
    }
}